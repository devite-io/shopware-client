{
  "compilerOptions": {
    "target": "es2024",
    "module": "es2022",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "./dist",
    "paths": {
      "#types/*": ["./types/*"],
      "@clients/*": ["./src/clients/*"],
      "@payloads/*": ["./src/payloads/*"],
      "@auth/*": ["./src/auth/*"],
      "@http/*": ["./src/http/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["./src/**/*.ts", "./types/**/*.ts"]
}
